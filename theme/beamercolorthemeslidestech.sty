%% This is file 'beamercolorthemeslidestech.sty'

% Requisitos básicos
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamercolorthemeslidestech}[16/05/2026 SlidesTech color theme]

% Definição de Opções
\RequirePackage{pgfopts}

\pgfkeys{
  /impatech/color/enfase/.cd,
    .is choice,
    padrao/.code=\impatech@enfase@padrao,
    matematica/.code=\impatech@enfase@matematica,
    dados/.code=\impatech@enfase@dados,
    computacao/.code=\impatech@enfase@computacao,
    fisica/.code=\impatech@enfase@fisica,
}

% Paletas de cores

% Cores neutras
\definecolor{preto}{HTML}{000000}
\definecolor{branco}{HTML}{FFFFFF}
\definecolor{cinza}{HTML}{A6A6A6}
\definecolor{bege100}{HTML}{FAF7ED} 
\definecolor{bege300}{HTML}{CCC4AF} % Oficial

% Ênfase de Matemática
\definecolor{matematica100}{HTML}{FFE9FD} 
\definecolor{matematica200}{HTML}{F59FED} 
\definecolor{matematica300}{HTML}{FF8AEF}  % Oficial
\definecolor{matematica400}{HTML}{D646C7} 

% Ênfase de Dados
\definecolor{dados300}{HTML}{ECF47A} % Oficial
\definecolor{dados400}{HTML}{C4CC5B} % Variação escura

% Ênfase de Computação
\definecolor{computacao100}{HTML}{FFEED9} 
\definecolor{computacao200}{HTML}{F7CB80}
\definecolor{computacao300}{HTML}{FFC555} % Oficial
\definecolor{computacao400}{HTML}{FCA72B} 

% Ênfase de Física
\definecolor{fisica100}{HTML}{E9FED8}
\definecolor{fisica200}{HTML}{B2E18B}
\definecolor{fisica300}{HTML}{BEFF8B} % Oficial
\definecolor{fisica400}{HTML}{7BEE1B}

% Macros (para aplicar as paletas de cores)

\newcommand{\impatech@enfase@padrao}{
    \colorlet{mainColor}{bege300}

    \setbeamercolor{normal text}{fg=preto, bg=branco}
    \setbeamercolor{structure}{fg=preto, bg=bege300}
}

\newcommand{\impatech@enfase@matematica}{
    \colorlet{mainColor}{matematica300}

    \setbeamercolor{normal text}{fg=preto, bg=branco}
    \setbeamercolor{structure}{fg=preto, bg=preto}
}

\newcommand{\impatech@enfase@dados}{
    \colorlet{mainColor}{dados300}

    \setbeamercolor{normal text}{fg=preto, bg=branco}
    \setbeamercolor{structure}{fg=preto, bg=preto}
}

\newcommand{\impatech@enfase@computacao}{
    \colorlet{mainColor}{computacao300}

    \setbeamercolor{normal text}{fg=preto, bg=branco}
    \setbeamercolor{structure}{fg=preto, bg=preto}
}

\newcommand{\impatech@enfase@fisica}{
    \colorlet{mainColor}{fisica300}

    \setbeamercolor{normal text}{fg=preto, bg=branco}
    \setbeamercolor{structure}{fg=preto, bg=preto}
}

% Elementos gerais

% Elementos da capa
\setbeamercolor{titlelike}{use=preto, parent=branco}
\setbeamercolor{author}{use=preto, parent=normal text}
\setbeamercolor{date}{use=preto, parent=normal text}
\setbeamercolor{institute}{use=preto, parent=normal text}

% Elementos do sumário
\setbeamercolor{section number projected}{bg=mainColor, fg=preto}
\setbeamercolor{section in toc}{fg=preto}
\setbeamercolor{subsection in toc}{fg=preto}

% Elementos de lista
\setbeamercolor{itemize item}{fg=mainColor}
\setbeamercolor{itemize subitem}{fg=preto}
\setbeamercolor{itemize subsubitem}{fg=cinza}

% Destaque
\setbeamercolor{alerted text}{fg=computacao300}

% Processamento de opções
\newcommand{\impatech@color@setdefaults}{
  \pgfkeys{/impatech/color/.cd, enfase=padrao}
}

% Aplica o default antes de processar as opções
\impatech@color@setdefaults
\ProcessPgfPackageOptions{/impatech/color}

\mode<all>

