%% This is file 'beamercolorthemeslidestech.sty'

% Requisitos básicos
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamercolortheslidestech}[16/05/2026 SlidesTech color theme]
\RequirePackage{pgfopts}

% Regras de configuração

\pgfkeys{
  /impatech/color/tema/.cd,
    .is choice,
    padrao/.code=\impa@tema@padrao,
    matematica/.code=\impa@tema@matematica,
    dados/.code=\impa@tema@dados,
    computacao/.code=\impa@tema@computacao,
    fisica/.code=\impa@tema@fisica,
}

\newcommand{\impa@color@setdefaults}{
  \pgfkeys{/impatech/color/.cd, tema=padrao} 
}

% Paletas de cores

% Cores neutras
\definecolor{Preto}{HTML}{000000}
\definecolor{Branco}{HTML}{FFFFFF}
\definecolor{Cinza}{HTML}{A6A6A6}
\definecolor{Bege100}{HTML}{FAF7ED} 
\definecolor{Bege300}{HTML}{CCC4AFFF} % Oficial

