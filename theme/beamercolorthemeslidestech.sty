% -------------------------------------------------------------
% REQUISITOS BÁSICOS 
% -------------------------------------------------------------

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamercolorthemeslidestech}[2026/05/16 SlidesTech color theme]

% -------------------------------------------------------------
% DEFINIÇÃO DAS OPÇÕES DE TEMA 
% -------------------------------------------------------------

\RequirePackage{pgfopts}

% Define a chave "enfase=" para o usuário escolher o tema
% Opções disponíveis: padrao, matematica, dados, computacao, fisica
\pgfkeys{
  /slidestech/color/enfase/.cd,
    .is choice,
    padrao/.code={\slidestech@enfase@padrao},
    matematica/.code={\slidestech@enfase@matematica},
    dados/.code={\slidestech@enfase@dados},
    computacao/.code={\slidestech@enfase@computacao},
    fisica/.code={\slidestech@enfase@fisica},
}

% -------------------------------------------------------------
% PALETA DE CORES 
% -------------------------------------------------------------

% Lógica da Escala Numérica:
% > Cor100: Tom claro -> Fundo do corpo dos blocos
% > Cor200: Tom intermediário -> Fundo da barra de progresso entre páginas
% > Cor300: Tom oficial -> Identidade principal do tema 
% > Cor400: Tom forte -> Fundo do cabeçalho dos blocos

% --- Paleta neutra ---

\definecolor{black}{HTML}{000000}
\definecolor{white}{HTML}{FFFFFF}
\definecolor{gray}{HTML}{A6A6A6}

% --- Paleta padrão (Bege) ---

\definecolor{beige100}{HTML}{FAF7ED} 
\definecolor{beige200}{HTML}{DFD9C9} 
\definecolor{beige300}{HTML}{CCC4AF} 

% --- Paleta de Matemática (Rosa) ---

\definecolor{math100}{HTML}{FFE9FD} 
\definecolor{math200}{HTML}{FFAFF5} 
\definecolor{math300}{HTML}{FF8AEF}  
\definecolor{math400}{HTML}{D646C7} 

% --- Paleta de Dados (Amarelo) ---

\definecolor{data200}{HTML}{F8FBB4}
\definecolor{data300}{HTML}{ECF47A}
\definecolor{data400}{HTML}{C4CC5B} 

% --- Paleta de Computação (Laranja) ---

\definecolor{comp100}{HTML}{FFEED9} 
\definecolor{comp200}{HTML}{FFD583}
\definecolor{comp300}{HTML}{FFC555} 
\definecolor{comp400}{HTML}{FCA72B} 

% --- Paleta de Física (Verde) ---

\definecolor{physics100}{HTML}{E9FED8}
\definecolor{physics200}{HTML}{D5FFB5}
\definecolor{physics300}{HTML}{BEFF8B} 
\definecolor{physics400}{HTML}{7BEE1B}

% -------------------------------------------------------------
% CONFIGURAÇÃO DE CADA TEMA 
% -------------------------------------------------------------

% Estrutura de Atribuição das Cores:
% > maincolor: Cor principal do tema (usada na capa, sumários, cabeçalhos e numeração de seções)
% > headercolor / textheadercolor: Fundo do cabeçalho do slide e cor do seu texto
% > progresscolor / backgroundprogresscolor: Barra de progresso e seu fundo
% > blocktitlecolor / blocktextcolor: Cabeçalho do bloco padrão e cor do seu texto

% --- Tema de Ênfase Padrão ---

\newcommand{\slidestech@enfase@padrao}{

    \colorlet{maincolor}{beige300}

    \colorlet{headercolor}{beige300}
    \colorlet{textheadercolor}{black}
    \colorlet{progresscolor}{black}
    \colorlet{backgroundprogresscolor}{beige200}

    \colorlet{blocktitlecolor}{beige300}
    \colorlet{blocktextcolor}{black}
}

% --- Tema de Ênfase de Matemática ---

\newcommand{\slidestech@enfase@matematica}{
    \colorlet{maincolor}{math300}

    \colorlet{headercolor}{black}
    \colorlet{textheadercolor}{white}
    \colorlet{progresscolor}{math300}
    \colorlet{backgroundprogresscolor}{math200}

    \colorlet{blocktitlecolor}{black}
    \colorlet{blocktextcolor}{white}
}

% --- Tema de Ênfase de Dados ---

\newcommand{\slidestech@enfase@dados}{
    \colorlet{maincolor}{data300}
    
    \colorlet{headercolor}{black}
    \colorlet{textheadercolor}{white}
    \colorlet{progresscolor}{data300}
    \colorlet{backgroundprogresscolor}{data200}

    \colorlet{blocktitlecolor}{black}
    \colorlet{blocktextcolor}{white}
}

% --- Tema de Ênfase de Computação ---

\newcommand{\slidestech@enfase@computacao}{
    \colorlet{maincolor}{comp300}

    \colorlet{headercolor}{black}
    \colorlet{textheadercolor}{white}
    \colorlet{progresscolor}{comp300}
    \colorlet{backgroundprogresscolor}{comp200}

    \colorlet{blocktitlecolor}{black}
    \colorlet{blocktextcolor}{white}
}

% --- Tema de Ênfase de Física ---

\newcommand{\slidestech@enfase@fisica}{
    \colorlet{maincolor}{physics300}

    \colorlet{headercolor}{black}
    \colorlet{textheadercolor}{white}
    \colorlet{progresscolor}{physics300}
    \colorlet{backgroundprogresscolor}{physics200}
    
    \colorlet{blocktitlecolor}{black}
    \colorlet{blocktextcolor}{white}
}

% -------------------------------------------------------------
% TEXTO E ESTRUTURA GERAL
% -------------------------------------------------------------

% --- Texto normal e estrutura base ---

\setbeamercolor{normal text}{fg=black, bg=white}
\setbeamercolor{structure}{fg=black}

% --- Capa ---

\setbeamercolor{titlelike}{use=black, parent=white}
\setbeamercolor{author}{use=black, parent=black}
\setbeamercolor{date}{use=black, parent=black}
\setbeamercolor{institute}{use=black, parent=black}

% --- Sumário ---

\setbeamercolor{section number projected}{bg=maincolor, fg=black}
\setbeamercolor{section in toc}{fg=black}
\setbeamercolor{subsection in toc}{fg=black}

% --- Lista (Itemize e Enumerate) ---

\setbeamercolor{itemize item}{fg=maincolor}
\setbeamercolor{itemize subitem}{fg=black}
\setbeamercolor{itemize subsubitem}{fg=gray}

% --- Texto em Destaque ---

\setbeamercolor{alerted text}{fg=comp300}

% -------------------------------------------------------------
% CABEÇALHO (HEADLINE)
% -------------------------------------------------------------

% --- Fundo do Cabeçalho ---

\setbeamercolor{header}{bg=headercolor, fg=white}

% --- Barra de Progresso ---

\setbeamercolor{progress bar}{bg=progresscolor, fg=white}

% -------------------------------------------------------------
% AMBIENTES DE BLOCOS
% -------------------------------------------------------------

% --- Bloco Padrão ---

% O cabeçalho tem cor beig (no tema padrão) ou preta (nas demais ênfases),
% sendo o corpo do bloco white (para todos os temas).
\setbeamercolor{block title}{fg=blocktextcolor, bg=blocktitlecolor} 
\setbeamercolor{block body}{fg=black, bg=white}

% --- Bloco de Alerta ---

% Mesma estrutura para todos os temas, com tons de laranja.
\setbeamercolor{block title alerted}{fg=black, bg=comp400}
\setbeamercolor{block body alerted}{fg=black, bg=comp100}

% --- Bloco de Exemplo ---

% Mesma estrutura para todos os temas, com tons de verde.
\setbeamercolor{block title example}{fg=black, bg=physics400}
\setbeamercolor{block body example}{fg=black, bg=physics100}

% --- Bloco de Teorema ---

% Mesma estrutura para todos os temas, com tons de rosa.
\setbeamercolor{block title theorem}{fg=white, bg=math400}
\setbeamercolor{block body theorem}{fg=black, bg=math100}

% --- Bloco de Prova ---

% Mesma estrutura para todos os temas, com tons de cinza.
\setbeamercolor{block title proof}{fg=gray, bg=gray}
\setbeamercolor{block body proof}{fg=black, bg=white}

% -------------------------------------------------------------
% SÍMBOLOS
% -------------------------------------------------------------

% --- QED ---

\setbeamercolor{qed symbol}{fg=gray, bg=gray}

% -------------------------------------------------------------
% PROCESSAMENTO DAS OPÇÕES
% -------------------------------------------------------------

% Define o tema padrao (Bege) como fallback, caso o usuário 
% não declare a ênfase no preâmbulo do arquivo principal.
\newcommand{\slidestech@color@setdefaults}{
  \pgfkeys{/slidestech/color/.cd, enfase=padrao}
}

% Aplica a configuração definida acima
\slidestech@color@setdefaults

% Sobrescreve as cores do tema com base na ênfase escolhida pelo usuário.
\ProcessPgfPackageOptions{/slidestech/color}

\mode<all>
\endinput