% --- Criação de Aliases/Redirecionamento das Chaves ---

\pgfkeys{
  /slidestech/font/.cd,
  titleformattitle/.code=\pgfkeysalso{titleformat title=#1},
  titleformatsubtitle/.code=\pgfkeysalso{titleformat subtitle=#1},
  titleformatsection/.code=\pgfkeysalso{titleformat section=#1},
  titleformatframe/.code=\pgfkeysalso{titleformat frame=#1},
}

% -------------------------------------------------------------
% PROJETOS DE MODIFICAÇÃO EXTERNA (PATCHES DO BEAMER)
% -------------------------------------------------------------

% Modificações via 'patchcmd' injetam as macros de caixa alta/baixa do PGFKeys 
% diretamente nos comandos internos e geradores de macros do núcleo do Beamer.

% Inicializadores das macros de transformação de texto (padrão: mantém texto original)
\def\slidestech@titleformat#1{#1}
\def\slidestech@subtitleformat#1{#1}
\def\slidestech@sectiontitleformat#1{#1}
\def\slidestech@frametitleformat#1{#1}

% Interceptação do Título Principal
\patchcmd{\beamer@title}%
  {\def\inserttitle{#2}}%
  {\def\inserttitle{\slidestech@titleformat{#2}}}%
  {}%
  {\PackageError{beamerfontthemeslidestech}{Patching title failed}\@ehc}

% Interceptação do Subtítulo
\patchcmd{\beamer@subtitle}%
  {\def\insertsubtitle{#2}}%
  {\def\insertsubtitle{\slidestech@subtitleformat{#2}}}%
  {}%
  {\PackageError{beamerfontthemeslidestech}{Patching subtitle failed}\@ehc}

% Interceptação da Entrada de Seções simples
\patchcmd{\sectionentry}
  {\def\insertsectionhead{#2}}
  {\def\insertsectionhead{\slidestech@sectiontitleformat{#2}}}
  {}
  {\PackageError{beamerfontthemeslidestech}{Patching section title failed}\@ehc}

% Interceptação de Cabeçalhos hiperlinkados de Seção (Método 1 e 2)
\@tempswafalse
\patchcmd{\beamer@section}
  {\def\insertsectionhead{\hyperlink{Navigation\the\c@page}{#1}}}
  {\def\insertsectionhead{\hyperlink{Navigation\the\c@page}{%
    \slidestech@sectiontitleformat{#1}}}}
  {\@tempswatrue}
  {}
\patchcmd{\beamer@section}
  {\protected@edef\insertsectionhead{\noexpand\hyperlink{Navigation\the\c@page}{#1}}}
  {\protected@edef\insertsectionhead{\noexpand\hyperlink{Navigation\the\c@page}{%
    \noexpand\slidestech@sectiontitleformat{#1}}}}
  {\@tempswatrue}
  {}
\if@tempswa\else
  \PackageError{beamerfontthemeslidestech}{Patching section title failed}\@ehc
\fi

% Interceptação de Cabeçalhos hiperlinkados de Subseção (Método 1 e 2)
\@tempswafalse
\patchcmd{\beamer@subsection}
  {\def\insertsubsectionhead{\hyperlink{Navigation\the\c@page}{#1}}}
  {\def\insertsubsectionhead{\hyperlink{Navigation\the\c@page}{%
    \slidestech@sectiontitleformat{#1}}}}
  {\@tempswatrue}
  {}
\patchcmd{\beamer@subsection}
  {\protected@edef\insertsubsectionhead{\noexpand\hyperlink{Navigation\the\c@page}{#1}}}
  {\protected@edef\insertsubsectionhead{\noexpand\hyperlink{Navigation\the\c@page}{%
    \noexpand\slidestech@sectiontitleformat{#1}}}}
  {\@tempswatrue}
  {}
\if@tempswa\else
  \PackageError{beamerfontthemeslidestech}{Patching section title failed}\@ehc
\fi

% Interceptação dos Títulos dos Frames (Gerenciador de quebra automática de texto)
\patchcmd{\beamer@@frametitle}
  {{%
      \gdef\insertframetitle{{#2\ifnum\beamer@autobreakcount>0\relax{}\space%
      \usebeamertemplate*{frametitle continuation}\fi}}%
    \gdef\beamer@frametitle{#2}%
    \gdef\beamer@shortframetitle{#1}%
    }}
  {{%
      \gdef\insertframetitle{{\slidestech@frametitleformat{#2}\ifnum%
      \beamer@autobreakcount>0\relax{}\space%
      \usebeamertemplate*{frametitle continuation}\fi}}%
    \gdef\beamer@frametitle{#2}%
    \gdef\beamer@shortframetitle{#1}%
    }}
  {}

% -------------------------------------------------------------
% PROCESSAMENTO DAS OPÇÕES
% -------------------------------------------------------------

% Define as opções padrão de estilo de fontes (modo de texto 'regular' sem modificadores)
\newcommand{\slidestech@font@setdefaults}{
  \pgfkeys{/slidestech/font/.cd,
    titleformat title=regular,
    titleformat subtitle=regular,
    titleformat section=regular,
    titleformat frame=regular,
  }
}

% Ativa as predefinições limpas
\slidestech@font@setdefaults

% Sobrescreve e compila os estilos de formatação conforme parâmetros passados pelo usuário
\ProcessPgfPackageOptions{/slidestech/font}

\endinput