\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerfontthemeslidestech}[16/05/2026 SlidesTech font theme]

% -------------------------------------------------------------
% REQUISITOS BÁSICOS 
% -------------------------------------------------------------

\RequirePackage{etoolbox}
\RequirePackage{ifxetex}
\RequirePackage{ifluatex}
\RequirePackage{pgfopts}
\RequirePackage{microtype}

% -------------------------------------------------------------
% CONFIGURAÇÃO DE FONTES POR MOTOR DE COMPILAÇÃO
% -------------------------------------------------------------

% Lógica de Seleção de Motores:
% > XeLaTeX / LuaLaTeX: Utiliza o pacote 'fontspec' para carregar fontes do sistema (OTF/TTF).
% > pdfLaTeX: Utiliza pacotes tradicionais do TeX (.sty) como fallback seguro.

\ifboolexpr{bool {xetex} or bool {luatex}}{
  
  % --- Configuração para Motores Modernos (XeLaTeX/LuaLaTeX) ---
  
  % Garante o carregamento do fontspec sem interferir nas fontes matemáticas nativas
  \@ifpackageloaded{fontspec}{
    \PassOptionsToPackage{no-math}{fontspec}
  }{
    \RequirePackage[no-math]{fontspec}
  }
  
  % Macro auxiliar para verificar se a fonte está instalada no sistema operacional
  \newcounter{fontsnotfound}
  \newcommand{\checkfont}[1]{%
    \suppressfontnotfounderror=1%
    \font\x = "#1" at 10pt
    \selectfont
    \ifx\x\nu\RequirePackage{microtype}llfont%
      \stepcounter{fontsnotfound}%
    \fi%
    \suppressfontnotfounderror=0%
  }

  % Condicional para aplicar configurações se a lista de fontes for encontrada
  \newcommand{\iffontsavailable}[3]{%
    \setcounter{fontsnotfound}{0}%
    \expandafter\forcsvlist\expandafter%
    \checkfont\expandafter{#1}%
    \ifnum\value{fontsnotfound}=0%
      #2%
    \else%
      #3%
    \fi%
  }
  
  % Tentativa 1: Carrega a família Roboto TrueType padrão do sistema
  \iffontsavailable{Roboto Light,%
                    Roboto Light Italic,%
                    Roboto Medium,%
                    Roboto Medium Italic}%
  {%
    \setsansfont[Ligatures={TeX,Common},%
                 ItalicFont={Roboto Light Italic},%
                 BoldFont={Roboto Medium},%
                 BoldItalicFont={Roboto Medium Italic}]%
                {Roboto Light}%
  }{%
    % Tentativa 2: Fallback para a variação OpenType (Roboto Light OT)
    \iffontsavailable{Roboto Light OT,%
                      Roboto Light Italic OT,%
                      Roboto Medium OT,%
                      Roboto Medium Italic OT}%
    {%
      \setsansfont[ItalicFont={Roboto Light Italic OT},%
                   BoldFont={Roboto Medium OT},%
                   BoldItalicFont={Roboto Medium Italic OT}]%
                  {Roboto Light OT}%
    }{%
      % Aviso caso nenhuma variação do Roboto seja localizada
      \PackageWarning{beamerthemeslidestech}{%
        Could not find Roboto fonts%
      }
    }
  }
  
  % Configuração da fonte monoespaçada (Roboto Mono) para códigos/tabelas
  \iffontsavailable{Roboto Mono, Roboto Mono Bold}{%
    \setmonofont[BoldFont={Roboto Mono Medium}]{Roboto Mono}%
  }{%
    \iffontsavailable{Roboto Mono OT, Roboto Mono Bold OT}{%
      \setmonofont[BoldFont={Roboto Mono Medium OT}]{Roboto Mono OT}%
    }{%
      \PackageWarning{beamerthemeslidestech}{%
        Could not find Roboto Mono fonts%
      }
    }
  }
  
  % Força o uso de números monoespaçados (alinhados) dentro de tabelas
  \AtBeginEnvironment{tabular}{%
    \addfontfeature{Numbers={Monospaced}}%
  }
}{%
  % --- Fallback Seguro para pdfLaTeX ---
  
  \RequirePackage[T1]{fontenc}
  
  % Tenta carregar o pacote da fonte Roboto principal
  \IfFileExists{roboto.sty}{%
    \RequirePackage[sfdefault,light,medium]{roboto}%
  }{%
    \PackageWarning{beamerthemeslidestech}{%
      Roboto font package not found. Falling back to Beamer default sans-serif.%
    }%
  }%
  
  % Tenta carregar o pacote da fonte Roboto Mono para código
  \IfFileExists{roboto-mono.sty}{%
    \RequirePackage{roboto-mono}%
  }{%
    \PackageWarning{beamerthemeslidestech}{%
      Roboto Mono font package not found. Falling back to Beamer default mono.%
    }%
  }%
}

% -------------------------------------------------------------
% DEFINIÇÃO DOS TAMANHOS E ESTILOS DE FONTE (BEAMER)
% -------------------------------------------------------------

% --- Elementos da Capa (Title Page) ---

\setbeamerfont{title}{size=\huge, series=\bfseries}
\setbeamerfont*{subtitle}{size=\normalsize}
\setbeamerfont{author}{size=\small}
\setbeamerfont{date}{size=\small}
\setbeamerfont{institute}{size=\small}

% --- Elementos de Estrutura e Cabeçalhos ---

\setbeamerfont{frametitle}{size=\Large, series=\bfseries}
\setbeamerfont{section title}{size=\Large, series=\bfseries}
\setbeamerfont{subsection title}{size=\large, series=\normalfont}

% --- Elementos de Blocos e Conteúdo ---

\setbeamerfont{block title}{size=\normalsize, series=\bfseries}
\setbeamerfont{standout}{size=\large, series=\bfseries}

% --- Legendas e Elementos de Suporte ---

\setbeamerfont{caption}{size=\small}
\setbeamerfont{caption name}{series=\bfseries}
\setbeamerfont{page number in head/foot}{size=\scriptsize}
\setbeamerfont{footnote}{size=\scriptsize}

% --- Elementos Bibliográficos (ABNT / Referências) ---

\setbeamerfont{bibliography entry author}{size=\normalsize, series=\normalfont}
\setbeamerfont{bibliography entry title}{size=\normalsize, series=\bfseries}
\setbeamerfont{bibliography entry location}{size=\normalsize, series=\normalfont}
\setbeamerfont{bibliography entry note}{size=\small, series=\normalfont}

% -------------------------------------------------------------
% CONFIGURAÇÃO DAS OPÇÕES DE FORMATAÇÃO DE TEXTO
% -------------------------------------------------------------

% --- Formatação do Título Principal ---

\pgfkeys{
  /slidestech/font/titleformat title/.cd,
    .is choice,
    regular/.code={%
      \let\slidestech@titleformat\@empty%
      \setbeamerfont{title}{shape=\normalfont}%
    },
    smallcaps/.code={%
      \let\slidestech@titleformat\@empty%
      \setbeamerfont{title}{shape=\scshape}%
    },
    allsmallcaps/.code={%
      \let\slidestech@titleformat\lowercase%
      \setbeamerfont{title}{shape=\scshape}%
      \PackageWarning{beamerthemeslidestech}{%
        Be aware that titleformat title=allsmallcaps can lead to problems%
      }
    },
    allcaps/.code={%
      \let\slidestech@titleformat\uppercase%
      \setbeamerfont{title}{shape=\normalfont}%
      \PackageWarning{beamerthemeslidestech}{%
        Be aware that titleformat title=allcaps can lead to problems%
      }
    },
}

% --- Formatação do Subtítulo ---

\pgfkeys{
  /slidestech/font/titleformat subtitle/.cd,
    .is choice,
    regular/.code={%
      \let\slidestech@subtitleformat\@empty%
      \setbeamerfont{subtitle}{shape=\normalfont}%
    },
    smallcaps/.code={%
      \let\slidestech@subtitleformat\@empty%
      \setbeamerfont{subtitle}{shape=\scshape}%
    },
    allsmallcaps/.code={%
      \let\slidestech@subtitleformat\lowercase%
      \setbeamerfont{subtitle}{shape=\scshape}%
      \PackageWarning{beamerthemeslidestech}{%
        Be aware that titleformat subtitle=allsmallcaps can lead to problems%
      }
    },
    allcaps/.code={%
      \let\slidestech@subtitleformat\uppercase%
      \setbeamerfont{subtitle}{shape=\normalfont}%
      \PackageWarning{beamerthemeslidestech}{%
        Be aware that titleformat subtitle=allcaps can lead to problems%
      }
    },
}

% --- Formatação dos Títulos de Seção ---

\pgfkeys{
  /slidestech/font/titleformat section/.cd,
    .is choice,
    regular/.code={%
      \let\slidestech@sectiontitleformat\@empty%
      \setbeamerfont{section title}{shape=\normalfont}%
    },
    smallcaps/.code={%
      \let\slidestech@sectiontitleformat\@empty%
      \setbeamerfont{section title}{shape=\scshape}%
    },
    allsmallcaps/.code={%
      \let\slidestech@sectiontitleformat\MakeLowercase%
      \setbeamerfont{section title}{shape=\scshape}%
