% -------------------------------------------------------------
% REQUISITOS BÁSICOS 
% -------------------------------------------------------------

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerinnerthemeslidestech}[16/05/2026 SlidesTech inner theme]

\RequirePackage{etoolbox}
\RequirePackage{keyval}
\RequirePackage{calc}
\RequirePackage{pgfopts}
\RequirePackage{tikz}
\RequirePackage{ifthen}
\RequirePackage[most]{tcolorbox}

% Carrega as bibliotecas necessárias para as formas geométricas e blocos flexíveis
\usetikzlibrary{calc} 
\tcbuselibrary{breakable}

% -------------------------------------------------------------
% CONFIGURAÇÃO DE CHAVES E OPÇÕES DO TEMA
% -------------------------------------------------------------

% Define as opções de comportamento para as páginas de Seção (Section Page)
% Opções: none (desativa a página) ou progressbar (exibe a página com a barra de progresso)
\pgfkeys{    
  /slidestech/inner/sectionpage/.cd,
    .is choice,
    none/.code=\slidestech@disablesectionpage,
    progressbar/.code={\slidestech@enablesectionpage
                      \setbeamertemplate{section page}[slidestech]},
}

% Define as opções de comportamento para as páginas de Subseção (Subsection Page)
% Opções: none (desativa a página) ou progressbar (exibe a página com a barra de progresso)
\pgfkeys{
  /slidestech/inner/subsectionpage/.cd,
    .is choice,
    none/.code=\slidestech@disablesubsectionpage,
    progressbar/.code={\slidestech@enablesubsectionpage
                      \setbeamertemplate{subsection page}[slidestech]},
}

% -------------------------------------------------------------
% CONFIGURAÇÃO DE VALORES PADRÃO
% -------------------------------------------------------------

% Default: Página de seção ativada com barra de progresso,
% página de subseção desativada por padrão.
\newcommand{\slidestech@inner@setdefaults}{
  \pgfkeys{/slidestech/inner/.cd,
    sectionpage=progressbar,
    subsectionpage=none
  }
}

% -------------------------------------------------------------
% CONFIGURAÇÃO DA CAPA (TITLE PAGE)
% -------------------------------------------------------------

% --- Layout Geral da Capa ---

\setbeamertemplate{title page}{
  \begin{minipage}[b][\paperheight]{\textwidth}
    \usebeamertemplate*{title separator}

    \vspace*{0.28\paperheight}
    
    \ifx\inserttitlegraphic\@empty\else\usebeamertemplate*{title graphic}\fi
    \vfill%
    \ifx\inserttitle\@empty\else\usebeamertemplate*{title}\fi
    \ifx\insertsubtitle\@empty\else\usebeamertemplate*{subtitle}\fi
    \ifx\beamer@shortauthor\@empty\else\usebeamertemplate*{author}\fi
    \ifx\insertdate\@empty\else\usebeamertemplate*{date}\fi
    \ifx\insertinstitute\@empty\else\usebeamertemplate*{institute}\fi
    \vfill
    \vspace*{1mm}
  \end{minipage}
}

% Redefinição dos comandos internos para carregar a capa em modo plain (sem barras/cabeçalhos)
\def\maketitle{%
  \ifbeamer@inframe
    \titlepage
  \else
    \frame[plain,noframenumbering]{\titlepage}
  \fi
}

\def\titlepage{%
  \usebeamertemplate{title page}
}

% --- Elementos Visuais da Capa ---

% Gráfico/Logo da Capa (Posicionado no canto superior esquerdo)
\setbeamertemplate{title graphic}{
  \begin{tikzpicture}[remember picture, overlay]
    \node[anchor=north west, inner sep=0pt] 
      at ([xshift=1cm, yshift=-1cm]current page.north west) 
      {\inserttitlegraphic};
  \end{tikzpicture}
}

% Título Principal
\setbeamertemplate{title}{
  \raggedright%
  \linespread{1.0}%
  \inserttitle%
  \par%
  \vspace*{0.5em}
}

% Subtítulo
\setbeamertemplate{subtitle}{
  \raggedright%
  \insertsubtitle%
  \par%
  \vspace*{0.5em}
}

% Divisor Geométrico (Faixa superior colorida na capa)
\newlength{\slidestech@titleseparator@linewidth}
\setlength{\slidestech@titleseparator@linewidth}{2pt}
\setbeamertemplate{title separator}{
  \begin{tikzpicture}[remember picture, overlay]
    \fill[maincolor] 
      (current page.north west) 
      rectangle 
      ([yshift=1/3*\paperheight]current page.south east);
    \fill[black] ([yshift=1/3*\paperheight]current page.south west) 
      rectangle 
      ([yshift=1/3*\paperheight + \slidestech@titleseparator@linewidth]current page.south east);
  \end{tikzpicture}%
  \par%
}

% Metadados (Autor, Data e Instituição)
\setbeamertemplate{author}{
  \vspace*{3.5em}
  \insertauthor%
  \par%
  \vspace*{0.25em}
}

\setbeamertemplate{date}{
  \insertdate%
  \par%
}

\setbeamertemplate{institute}{
  \vspace*{3mm}
  \insertinstitute%
  \par%
}

% -------------------------------------------------------------
% SUMÁRIO (TABLE OF CONTENTS)
% -------------------------------------------------------------

% Estilo padrão dos marcadores das Seções (Quadrados)
\setbeamertemplate{sections/subsections in toc}[square]

% Layout customizado para as Subseções no Sumário (Marcadas com Bullet)
\setbeamertemplate{subsection in toc}{%
  \leavevmode\leftskip=2.7em%
  \usebeamerfont{subsection in toc}%
  \rlap{\hskip-1.5em\raise.2ex\hbox{\small$\bullet$}}%
  \inserttocsubsection\par%
}

% NOTA DE SUPORTE: As cores dos elementos do ToC (section number projected,
% section in toc, subsection in toc) são definidas exclusivamente no 'colortheme'.

% -------------------------------------------------------------
% LISTAS (ITEMIZE E ENUMERATE)
% -------------------------------------------------------------

% --- Marcadores do Itemize (Círculos via TikZ) ---

\setbeamertemplate{itemize item}{
  \tikz\draw[maincolor, fill=maincolor] circle (0.13cm);
}
\setbeamertemplate{itemize subitem}{
  \tikz\draw[maincolor, line width=0.8pt] circle (0.10cm);
}
\setbeamertemplate{itemize subsubitem}{
  \tikz\draw[maincolor, fill=maincolor] circle (0.06cm);
}

% --- Marcadores do Enumerate (Quadrados Numerados via TikZ) ---

\setbeamertemplate{enumerate item}{%
  \tikz\node[fill=maincolor, text=black, font=\tiny\bfseries,
    inner sep=2pt, minimum size=0.32cm] {\insertenumlabel};%
}
\setbeamertemplate{enumerate subitem}{%
  \tikz\node[draw=maincolor, line width=0.8pt, text=maincolor, font=\tiny\bfseries,
    inner sep=2pt, minimum size=0.28cm] {\insertenumlabel};%
}
\setbeamertemplate{enumerate subsubitem}{%
  \tikz\node[fill=maincolor!50, text=black!70, font=\tiny\bfseries,
    inner sep=2pt, minimum size=0.24cm] {\insertenumlabel};%
}

% -------------------------------------------------------------
% PÁGINAS DE TRANSIÇÃO (SECTION & SUBSECTION PAGE)
% -------------------------------------------------------------

\providecommand{\inserttotalframenumber}{100}

% Variáveis para medição e desenho da barra de progresso
\newlength{\slidestech@progressonsectionpage}
\newlength{\slidestech@progressonsectionpage@linewidth}
\setlength{\slidestech@progressonsectionpage@linewidth}{1pt}

% Mecanismo da Barra de Progresso nas páginas de Seção
\setbeamertemplate{progress bar in section page}{
  \setlength{\slidestech@progressonsectionpage}{%
    \textwidth * \ratio{\insertframenumber pt}{\inserttotalframenumber pt}%
  }%
  \begin{tikzpicture}
    \fill[maincolor!60] (0,0) rectangle (0.5*\textwidth, \slidestech@progressonsectionpage@linewidth);
    \fill[black] (0,0) rectangle (0.5*\slidestech@progressonsectionpage, \slidestech@progressonsectionpage@linewidth);
  \end{tikzpicture}%
}

% --- Layout Estrutural da Section Page ---

\defbeamertemplate{section page}{slidestech}{
  \begin{minipage}[b][\paperheight]{\textwidth}
    \begin{tikzpicture}[remember picture, overlay]
      \fill[maincolor] 
        (current page.north west) 
        rectangle 
        ([yshift=1/3*\paperheight]current page.south east);
    \end{tikzpicture}%
    \vspace*{0.1\paperheight} 
    \vfill

    % Título da Seção Principal (Aplica fontes configuradas no tema de fontes)
    \begin{beamercolorbox}[wd=\textwidth]{section title}
      \raggedright
      \usebeamerfont{section title}
      \insertsectionhead\par
    \end{beamercolorbox}
    \vspace*{0.3em}

    % Subtítulo da Seção (Renderizado condicionalmente caso exista)
    \ifx\insertsubsectionhead\@empty\else
      \begin{beamercolorbox}[wd=\textwidth]{subsection title}
        \raggedright
        \usebeamerfont{subsection title}
        \insertsubsectionhead\par
      \end{beamercolorbox}
      \vspace*{0.3em}
    \fi
    
    % Inserção da Barra de Progresso
    \begin{beamercolorbox}[wd=\textwidth]{progress bar container}
      \usebeamertemplate*{progress bar in section page}
    \end{beamercolorbox}
    \vspace*{0.5em}
    \vfill
    \vspace*{1mm}
  \end{minipage}
}

% Vincula o template da Subsection Page para espelhar o comportamento da Section Page
\setbeamertemplate{subsection page}{%
  \usebeamertemplate*{section page}%
}

% --- Ganchos de Ativação Automática (Hooks) ---

\newcommand{\slidestech@disablesectionpage}{\AtBeginSection{}}
\newcommand{\slidestech@enablesectionpage}{
  \AtBeginSection{
    \ifbeamer@inframe\else
      \frame[plain,c,noframenumbering]{\usebeamertemplate*{section page}}
    \fi
  }
}

\newcommand{\slidestech@disablesubsectionpage}{\AtBeginSubsection{}}
\newcommand{\slidestech@enablesubsectionpage}{
  \AtBeginSubsection{
    \ifbeamer@inframe\else
      \frame[plain,c,noframenumbering]{\usebeamertemplate*{subsection page}}
    \fi
  }
}

% -------------------------------------------------------------
% SLIDE DE DESTAQUE (STANDOUT FRAME)
% -------------------------------------------------------------

\providebool{slidestech@standout}
\def\slidestech@standout@fg{black}

\pgfkeys{
  /slidestech/standout/.cd,
  fg/.store in=\slidestech@standout@fg,
}

% Configuração interna do frame [standout] para limpar elementos (header/footer/canvas)
\define@key{beamerframe}{standout}[]{%
  \booltrue{slidestech@standout}%
  \def\slidestech@standout@fg{black}%
  \pgfkeys{/slidestech/standout/.cd, #1}%
  \begingroup%
    \setkeys{beamerframe}{c}%
    \setkeys{beamerframe}{plain}%
    \setkeys{beamerframe}{noframenumbering}%
    \setbeamertemplate{headline}{}%
    \setbeamertemplate{footline}{}%
    \setbeamertemplate{navigation symbols}{}%
    \setbeamertemplate{sidebar right}{}%
    \setbeamertemplate{sidebar left}{}%
    \setbeamercolor{background canvas}{bg=white}%
  \centering%
  \Large\bfseries%
  \color{\slidestech@standout@fg}%
}

% Restaura as configurações normais do Beamer ao encerrar o frame standout
\apptocmd{\beamer@reseteecodes}{%
  \ifbool{slidestech@standout}{%
    \endgroup%
    \boolfalse{slidestech@standout}%
  }{}%
}{}{}

% Caixa de Destaque centralizada construída em tcolorbox
\newenvironment{standoutbox}[1][maincolor]{%
  \begin{tcolorbox}[
    enhanced, rounded corners,
    boxrule=1.5pt,
    colback=#1!20, colframe=#1, coltitle=black,
    left=12pt, right=12pt, top=10pt, bottom=10pt, middle=0pt,
    halign=flush center,
    width=0.75\textwidth
  ]%
  \Large\bfseries
}{%
  \end{tcolorbox}%
}

% -------------------------------------------------------------
% COMPONENTES VISUAIS (PILLS)
% -------------------------------------------------------------

% Destacador de texto em formato de cápsula arredondada
\newcommand{\pill}[2][data300]{%
  \tcbox[%
    on line,
    arc=4pt,
    colback=#1,
    colframe=#1,
    boxsep=0pt,
    left=3pt, right=3pt,
    top=1.5pt, bottom=1.5pt,
    boxrule=0pt,
  ]{#2}%
}

% Variante da pílula aplicando negrito automático no texto inserido
\newcommand{\pillbf}[2][data300]{%
  \pill[#1]{\textbf{#2}}%
}

% -------------------------------------------------------------
% AMBIENTES DE BLOCOS CUSTOMIZADOS (TCOLORBOX)
% -------------------------------------------------------------

% Lógica de Importação de Cores:
% Os blocos herdam as definições dinâmicas de cores configuradas no 'colortheme'
% através do comando \usebeamercolor antes de renderizar as propriedades do tcolorbox.

% --- Bloco Padrão ---
\defbeamertemplate{block begin}{slidestech}{
  \usebeamercolor{block body}
  \usebeamercolor{block title}
  \begin{tcolorbox}[
    enhanced, breakable, rounded corners, boxrule=0.8pt,                
    colback=block body.bg, coltext=block body.fg,         
    colframe=block title.bg, coltitle=block title.fg,               
    fonttitle=\bfseries,          
    left=5pt, right=5pt, top=5pt, bottom=5pt, middle=0pt,
    toptitle=3pt, bottomtitle=3pt, title=\insertblocktitle
  ]
}
\defbeamertemplate{block end}{slidestech}{\end{tcolorbox}}

% --- Bloco de Alerta ---
\defbeamertemplate{block alerted begin}{slidestech}{
  \usebeamercolor{block body alerted}
  \usebeamercolor{block title alerted}
  \begin{tcolorbox}[
    enhanced, breakable, rounded corners, boxrule=0.8pt,
    colback=block body alerted.bg, coltext=block body alerted.fg,
    colframe=block title alerted.bg, coltitle=block title alerted.fg,
    fonttitle=\bfseries,
    left=5pt, right=5pt, top=5pt, bottom=5pt, middle=0pt,
    toptitle=3pt, bottomtitle=3pt, title=\insertblocktitle
  ]
}
\defbeamertemplate{block alerted end}{slidestech}{\end{tcolorbox}}

% --- Bloco de Exemplo ---
\defbeamertemplate{block example begin}{slidestech}{
  \usebeamercolor{block body example}
  \usebeamercolor{block title example}
  \begin{tcolorbox}[
    enhanced, breakable, rounded corners, boxrule=0.8pt,
    colback=block body example.bg, coltext=block body example.fg,
    colframe=block title example.bg, coltitle=block title example.fg,
    fonttitle=\bfseries,
    left=5pt, right=5pt, top=5pt, bottom=5pt, middle=0pt,
    toptitle=3pt, bottomtitle=3pt, title=\insertblocktitle
  ]
}
\defbeamertemplate{block example end}{slidestech}{\end{tcolorbox}}

% --- Bloco de Teorema ---
\defbeamertemplate{theorem begin}{slidestech}{
  \usebeamercolor{block body theorem}
  \usebeamercolor{block title theorem}
  \begin{tcolorbox}[
    enhanced, breakable, rounded corners, boxrule=0.8pt,              
    colback=block body theorem.bg, coltext=block body theorem.fg,    
    colframe=block title theorem.bg, coltitle=block title theorem.fg,         
    fonttitle=\bfseries,      
    left=5pt, right=5pt, top=5pt, bottom=5pt, middle=0pt,
    toptitle=3pt, bottomtitle=3pt, title=Teorema
  ]
}
\defbeamertemplate{theorem end}{slidestech}{\end{tcolorbox}}

% --- Bloco de Prova ---
\defbeamertemplate{proof begin}{slidestech}{
  \usebeamercolor{block body proof}
  \usebeamercolor{block title proof}
  \begin{tcolorbox}[
    enhanced, breakable, rounded corners, boxrule=0.8pt,              
    colback=block body proof.bg, coltext=block body proof.fg,
    colframe=block title proof.bg, coltitle=block title proof.fg,   
    fonttitle=\bfseries,
    attach title to upper={\par}, after title={\medskip},       
    left=5pt, right=5pt, top=5pt, bottom=5pt, middle=0pt,
    toptitle=3pt, bottomtitle=3pt, title=Prova.
  ]
}
\defbeamertemplate{proof end}{slidestech}{\end{tcolorbox}}

