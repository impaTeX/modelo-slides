%% This is file 'beamerouterthemeslidestech.sty'
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerouterthemeslidestech}[16/05/2026 IMPA Tex outer theme]

% =====================================================================================
% 1. PACOTES ADICIONAIS
\RequirePackage{tikz}       % Usado para desenhar o círculo do marcador de página
\RequirePackage{calc}       % Para calcular dimensões de comprimento
\RequirePackage{graphicx}   % Utilizada para inserir imagens (logo)
% =====================================================================================

% =====================================================================================
% 2. CORES DE TESTE
\setbeamertemplate{navigation symbols}{}    % Remove os ícones de navegação padrão do Beamer

% 2.1 Cores de teste
\definecolor{TesteBege}{HTML}{CCC4AF}   % Bege feio
\definecolor{TestePreto}{HTML}{000000}  % Preto goat
\definecolor{TesteCinza}{HTML}{999999}  % Cinza (para a parte de texto do rodapé)

% 2.2 Define as cores do background do cabeçalho
\setbeamercolor{frametitle}{bg=TesteBege, fg=TestePreto}
% =====================================================================================

% =====================================================================================
% 3. ESTRUTURA DO CABEÇALHO

% Sobrescreve o Layout padrão do beamer pelo nosso
\defbeamertemplate*{frametitle}{slidestech}
{
    % 3.1 Título (parte textual)
    \nointerlineskip    % Garante que o conteúdo fique "grudado" no início da página

    % Cria uma "caixa" para conter o cabeçalho
    \begin{beamercolorbox}[
        wd=\paperwidth, % Largura (tamanho da página)
        ht=1.0cm,       % Altura
        dp=0.10cm,      % Profundidade
        sep=0pt         % Remove padding automático
    ]{frametitle}

        % Cria uma linha horizontal do tamanho do slide (para conter os elementos)
        \hbox to \paperwidth{

            \raisebox{0.3cm}{               % Centraliza o título
                {\usebeamerfont{frametitle} % Puxa fonte padrão para títulos
                 \bfseries                  % Negrito
                 \Large                     % Deixa grande
                 \insertframetitle}         % Insere o texto
            }

            \hfill  % Garante que o texto fique na esquerda e a logo na direita

            % 3.2 Logo
            \includegraphics[           % Insere a imagem da logo
                height=0.8cm            % Altura da logo
            ]{../images/logo_03.png}    % Logo/arquivo de imagem

            \hspace*{0.8cm} % Adiciona margem da logo com a borda direita da página
        }

    \end{beamercolorbox}

    % 3.3 Barra de Progresso
        \nointerlineskip

        \begin{beamercolorbox}[
            wd=\paperwidth,     % A caixa ocupa a largura total da página
            ht=3pt,             % Espessura da barra
            leftskip=0pt,
            rightskip=0pt,
            sep=0pt
        ]{}
        
            % Evita divisão por zero
            \ifnum\inserttotalframenumber>0
                % Calcula a largura da barra preta proporcionalmente ao slide atual
                \rule{\dimexpr\paperwidth*\insertframenumber/\inserttotalframenumber\relax}{3pt}
            \else
                % Fallback
                \rule{0pt}{3pt}
            \fi

        \end{beamercolorbox}

    % Espaço abaixo da linha para evitar que ela entre em contato com o conteúdo
    \vspace{0.15cm}

}
% =====================================================================================

% =====================================================================================
% 4. ESTRUTURA DE RODAPÉ

\defbeamertemplate*{footline}{slidestech}
{
    \leavevmode

    \hbox{  % Abre uma box horizontal para conter o rodapé

        % 4.1. Texto

        % Cria uma caixa para conter o texto do rodapé
        \begin{beamercolorbox}[
            wd=.88\paperwidth,  % Largura de 88% da página
            ht=.8cm,            % Altura
            dp=.4cm,            % Profundidade
            left,               % Alinha a esquerda
            leftskip=0.3cm      % Adiciona uma margem com a borda esquerda da página
        ]{}

            % O \raisebox com valor negativo empurra apenas este texto para baixo
            \raisebox{-0.15cm}{%
                \textcolor{TesteCinza}{
                    \small                  % Deixa o texto pequeno
                    \insertshortauthor      % Nome do autor
                    \ |                     % Barra de separação
                    \insertshorttitle       % Título da apresentação
                    \ |                     % Barra de separação
                    \insertshortinstitute   % Nome da instituição
                }%
            }

        \end{beamercolorbox}

        % 4.2. Numeração de páginas

        \begin{beamercolorbox}[ % Cria outra caixa para ocupar o resto do rodapé
            wd=.1\paperwidth,   % Largura de 10% da página
            ht=.9cm,            % Altura
            dp=.5cm,            % Profundidade
            rightskip=2cm,      % Adiciona margem com a borda direita
            right               % "Empurra" para o lado direito
        ]{}

            % Inicia o desenho de uma forma com texto dentro
            \begin{tikzpicture}[baseline=(page.center)]

                % Desenha o modelo para numerar as páginas:
                \node[
                    circle,                 % Forma círculo
                    fill=TesteBege,         % Preenchimento com a cor base (bege) definida em (2.1)
                    text=TestePreto,        % Deixa o texto com a cor preta definida em (2.1)
                    minimum size=0.65cm,    % Diâmetro do círculo
                    inner sep=0pt,          % Remove espaçamento interno
                    font=\small\bfseries    % Define fonte
                ] (page)
                {   
                    % Garante que sempre apareçam 2 algarismos
                    \ifnum\insertframenumber<10 0\fi
                    \insertframenumber
                };

            \end{tikzpicture}

        \end{beamercolorbox}

    }

    \vskip0pt   % Garante que o rodapé fique "colado" na parte inferior do slide
}
% =====================================================================================

% 5. ATIVAÇÃO DOS TEMPLATES

\setbeamertemplate{frametitle}[slidestech]
\setbeamertemplate{footline}[slidestech]