% -------------------------------------------------------------
% REQUISITOS BÁSICOS 
% -------------------------------------------------------------

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerouterthemeslidestech}[16/05/2026 IMPA Tex outer theme]

% -------------------------------------------------------------
% PACOTES ADICIONAIS
% -------------------------------------------------------------

% "tikz" - usado para desenhar o círculo do marcador de página
% "calc" - usado para calcular as dimensões de comprimento da headline e footline
%  "graphicx" - usado para inserir imagens
\RequirePackage{tikz}
\RequirePackage{calc}
\RequirePackage{graphicx}
\RequirePackage{etoolbox}

% -------------------------------------------------------------
% CORES
% -------------------------------------------------------------

% Remove os ícones de navegação padrão do Beamer
\setbeamertemplate{navigation symbols}{}

% Define as cores do background do cabeçalho usando o arquivo color
\setbeamercolor{frametitle}{bg=headercolor, fg=textheadercolor}

% -------------------------------------------------------------
% ESTRUTURA DO CABEÇALHO
% -------------------------------------------------------------

\defbeamertemplate*{frametitle}{slidestech}
{

% --- Parte textual ---
    \nointerlineskip

    % Cria uma caixa para conter o cabeçalho
    \begin{beamercolorbox}[
        wd=\paperwidth, % Largura de 100% da página
        ht=1.0cm,       % Altura
        dp=0.10cm,      % Profundidade
        sep=0pt         % Remove padding automático
    ]{frametitle}

        % Cria uma linha horizontal do tamanho do slide para conter os elementos
        \hbox to \paperwidth{

            % Fonte
            \raisebox{0.3cm}{               % Centraliza o título
                {\usebeamerfont{frametitle} % Puxa fonte padrão para títulos
                 \bfseries
                 \Large
                 \insertframetitle}
            }

            % Garante que o texto fique na esquerda e a logo na direita
            \hfill

% --- Logo ---
             % Adiciona margem da logo com a borda direita da página
            \insertlogo\hspace*{0.8cm}
        }

    \end{beamercolorbox}%
    %

% --- Barra de PRogresso --
    \nointerlineskip%
    \vspace*{-0.5pt}%
    \begin{beamercolorbox}[
        wd=\paperwidth,     % Cria uma caixa que ocupa a largura da página
        ht=2pt,             % Espessura da barra
        dp=0pt,             % Profundidade
        leftskip=0pt,
        rightskip=0pt,
        sep=0pt
    ]{}%
        \ifnum\inserttotalframenumber>0\relax
            % Calcula a largura da barra proporcionalmente ao slide atual
            \textcolor{progresscolor}{\rule{\dimexpr\paperwidth*\insertframenumber/\inserttotalframenumber\relax}{3pt}}%

            % Calcula a largura restante e pinta com a cor do cabeçalho
            \textcolor{headercolor}{\rule{\dimexpr\paperwidth - \paperwidth*\insertframenumber/\inserttotalframenumber\relax}{3pt}}%

        \else
            % Fallback (divisão por zero na primeira página)
            \textcolor{headercolor}{\rule{\paperwidth}{2pt}}%
        \fi
    \end{beamercolorbox}

    % Espaço abaixo da linha para evitar que ela entre em contato com o conteúdo
    \vspace{0.15cm}

}

% -------------------------------------------------------------
% ESTRUTURA DE RODAPÉ
% -------------------------------------------------------------

\defbeamertemplate*{footline}{slidestech}
{
    \leavevmode

    \hbox{

% --- Parte textual --

        % Cria uma caixa para conter o texto do rodapé
        \begin{beamercolorbox}[
            wd=.88\paperwidth,  % Largura de 88% da página
            ht=.8cm,            % Altura
            dp=.25cm,           % Profundidade
            left,               % Alinha a esquerda
            leftskip=0.3cm      % Adiciona uma margem com a borda esquerda da página
        ]{}

            % O \raisebox com valor negativo empurra apenas este texto para baixo
            \raisebox{-0.15cm}{%
                \textcolor{gray}{
                    \small
                    \insertshortauthor      % Nome do autor
                    \ |                     % Barra de separação
                    \insertshorttitle       % Título da apresentação
                    \ |                     % Barra de separação
                    \insertshortinstitute   % Nome da instituição
                }%
            }

        \end{beamercolorbox}

  % --- Numeração das páginas ---

        \begin{beamercolorbox}[ % Cria outra caixa para ocupar o resto do rodapé
            wd=.1\paperwidth,
            ht=.9cm,
            dp=.4cm,
            rightskip=1cm,      % Adiciona margem com a borda direita
            right               % "Empurra" para o lado direito
        ]{}

            % Inicia o desenho de uma forma com texto dentro
            \begin{tikzpicture}[baseline=(page.center)]

                \node[
                    circle,                 % Forma de círculo
                    fill=maincolor,         % Preenchimento com a cor base
                    text=black,             % Deixa o texto com a cor preta
                    minimum size=0.60cm,    % Diâmetro do círculo
                    inner sep=0pt,          % Remove espaçamento interno
                    font=\small\bfseries
                ] (page)
                {   
                    % Configura para exibição em 2 algarismos
                    \ifnum\insertframenumber<10 0\fi
                    \insertframenumber
                };

            \end{tikzpicture}

        \end{beamercolorbox}

    }

    % Garante que o rodapé fique "colado" na parte inferior do slide
    \vskip0pt
}

% -------------------------------------------------------------
% ATIVAÇÃO DOS TEMPLATES
% -------------------------------------------------------------

\setbeamertemplate{frametitle}[slidestech]
\setbeamertemplate{footline}[slidestech]
\endinput