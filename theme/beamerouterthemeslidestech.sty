% -------------------------------------------------------------
% REQUISITOS BÁSICOS 
% -------------------------------------------------------------

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerouterthemeslidestech}[16/05/2026 IMPA Tex outer theme]

% -------------------------------------------------------------
% PACOTES ADICIONAIS
% -------------------------------------------------------------

\RequirePackage{tikz}
\RequirePackage{calc}
\RequirePackage{graphicx}
\RequirePackage{etoolbox}

% -------------------------------------------------------------
% LIMPEZA DE ELEMENTOS PADRÃO E CORES
% -------------------------------------------------------------

% Remove os ícones de navegação padrão do Beamer
\setbeamertemplate{navigation symbols}{}

% Remove a logo flutuante automática do Beamer no canto inferior direito
\setbeamertemplate{sidebar right}{}
\setbeamertemplate{sidebar left}{}

% Define as cores do background do cabeçalho usando o arquivo color
\setbeamercolor{frametitle}{bg=headercolor, fg=textheadercolor}

% -------------------------------------------------------------
% ESTRUTURA DO CABEÇALHO
% -------------------------------------------------------------

\defbeamertemplate*{frametitle}{slidestech}
{
    \nointerlineskip

    % Caixa do cabeçalho com padding (sep) automático em vez de altura fixa
    \begin{beamercolorbox}[
        wd=\paperwidth, 
        sep=0.35cm,       % Espaçamento interno (padding) topo e base
        leftskip=0.2cm,   % Margem esquerda
        rightskip=0.2cm   % Margem direita
    ]{frametitle}
        % Título
        {\usebeamerfont{frametitle}\bfseries\Large\insertframetitle}%
        \hfill%
        % Logo (Abaixada levemente para centralizar com o texto)
        \raisebox{-0.15cm}{\insertlogo}%
    \end{beamercolorbox}%
    
    \nointerlineskip

    % Barra de Progresso
    \begin{beamercolorbox}[
        wd=\paperwidth,
        ht=1pt,           % Altura exata da barra
        dp=0pt,
        sep=0pt
    ]{}%
        \ifnum\inserttotalframenumber>0\relax
            % Calcula a largura da barra proporcionalmente ao slide atual
            \textcolor{progresscolor}{\rule{\dimexpr\paperwidth*\insertframenumber/\inserttotalframenumber\relax}{3pt}}%
            % Pinta o restante com a cor de fundo
            \textcolor{headercolor}{\rule{\dimexpr\paperwidth - \paperwidth*\insertframenumber/\inserttotalframenumber\relax}{3pt}}%
        \else
            % Fallback (divisão por zero na primeira página)
            \textcolor{headercolor}{\rule{\paperwidth}{1pt}}%
        \fi
    \end{beamercolorbox}
}

% -------------------------------------------------------------
% ESTRUTURA DE RODAPÉ
% -------------------------------------------------------------

\defbeamertemplate*{footline}{slidestech}
{
    \leavevmode
    \hbox{%

        % --- Parte textual ---
        \begin{beamercolorbox}[
            wd=.88\paperwidth,
            ht=.8cm,
            dp=.25cm,
            left,
            leftskip=0.3cm
        ]{}
            \raisebox{-0.15cm}{%
                \textcolor{gray}{%
                    \small
                    \insertshortauthor      \ | 
                    \insertshorttitle       \ | 
                    \insertshortinstitute
                }%
            }
        \end{beamercolorbox}%
        % --- Numeração das páginas ---
        \begin{beamercolorbox}[
            wd=.1\paperwidth,
            ht=.9cm,
            dp=.4cm,
            rightskip=1cm,
            right
        ]{}
            \begin{tikzpicture}[baseline=(page.center)]
                \node[
                    circle,
                    fill=maincolor,
                    text=black,
                    minimum size=0.60cm,
                    inner sep=0pt,
                    font=\small\bfseries
                ] (page)
                {   
                    \ifnum\insertframenumber<10 0\fi
                    \insertframenumber
                };
            \end{tikzpicture}
        \end{beamercolorbox}%
    }
    \vskip0pt
}

% -------------------------------------------------------------
% ATIVAÇÃO DOS TEMPLATES
% -------------------------------------------------------------

\setbeamertemplate{frametitle}[slidestech]
\setbeamertemplate{footline}[slidestech]
\endinput